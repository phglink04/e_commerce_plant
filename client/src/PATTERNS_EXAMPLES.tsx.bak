/**
 * =====================================
 * PATTERN 1: Simple Product List Page
 * =====================================
 */

// ✅ Example: pages/shop/page.tsx
import { useProducts } from "@/hooks";
import { ProductList, Pagination } from "@/components/ui";
import { PAGINATION } from "@/constants";

export default function ShopPage() {
  const { products, loading, error, pagination, goToPage } = useProducts({
    initialPage: 1,
    limit: PAGINATION.DEFAULT_LIMIT,
  });

  return (
    <div className="container mx-auto p-4">
      <ProductList products={products} loading={loading} error={error} />

      {pagination.totalPages > 1 && (
        <Pagination
          currentPage={pagination.page}
          totalPages={pagination.totalPages}
          onPageChange={goToPage}
        />
      )}
    </div>
  );
}

/**
 * =====================================
 * PATTERN 2: Search + Filter Page
 * =====================================
 */

import { useState } from "react";
import { useProducts, useDebounce } from "@/hooks";
import { SearchBar, FilterSidebar, ProductList } from "@/components/ui";

export default function SearchPage() {
  const [search, setSearch] = useState("");
  const [filters, setFilters] = useState({
    category: "",
    tag: "",
    minPrice: 0,
    maxPrice: 1000000,
  });

  const debouncedSearch = useDebounce(search, 500);

  const { products, loading, error, pagination } = useProducts({
    search: debouncedSearch,
    category: filters.category,
    tag: filters.tag,
  });

  return (
    <div className="flex gap-6">
      <FilterSidebar
        categories={["Flower", "Herb", "Succulent"]}
        tags={["Indoor", "Outdoor"]}
        onFilterChange={setFilters}
      />

      <div className="flex-1">
        <SearchBar onSearch={setSearch} />
        <ProductList products={products} loading={loading} error={error} />
      </div>
    </div>
  );
}

/**
 * =====================================
 * PATTERN 3: Add to Cart with Notifications
 * =====================================
 */

import { useCart } from "@/hooks";
import { ProductCard } from "@/components/ui";
import { useState } from "react";

export default function ProductCardWithCart() {
  const { addToCart } = useCart();
  const [notification, setNotification] = useState("");

  const handleAddToCart = async (productId: string) => {
    try {
      const success = await addToCart(productId, 1);
      if (success) {
        setNotification("✅ Added to cart!");
        setTimeout(() => setNotification(""), 3000);
      } else {
        setNotification("❌ Failed to add to cart");
      }
    } catch (error) {
      setNotification("❌ Error: " + (error as any).message);
    }
  };

  return (
    <div>
      <ProductCard product={product} onAddToCart={handleAddToCart} />
      {notification && (
        <div className="fixed top-4 right-4 bg-white p-4 rounded shadow">
          {notification}
        </div>
      )}
    </div>
  );
}

/**
 * =====================================
 * PATTERN 4: Cart Page with Management
 * =====================================
 */

import { useCart } from "@/hooks";
import CartItemComponent from "@/components/cart-checkout/CartItem";
import { useEffect } from "react";

export default function CartPage() {
  const {
    cart,
    loading,
    getCart,
    updateQuantity,
    removeFromCart,
    totalPrice,
    totalItems,
  } = useCart();

  // Fetch cart on mount
  useEffect(() => {
    getCart();
  }, [getCart]);

  if (loading && !cart) {
    return <div>Loading...</div>;
  }

  if (!cart?.items?.length) {
    return <div>Your cart is empty</div>;
  }

  return (
    <div className="grid grid-cols-3 gap-8">
      {/* Cart Items */}
      <div className="col-span-2 space-y-4">
        {cart.items.map((item) => (
          <CartItemComponent
            key={item.plantId}
            item={item}
            onUpdateQuantity={updateQuantity}
            onRemove={removeFromCart}
          />
        ))}
      </div>

      {/* Summary */}
      <div className="bg-white p-6 rounded border">
        <h2 className="text-xl font-bold mb-4">Order Summary</h2>
        <div className="space-y-2 mb-4">
          <div className="flex justify-between">
            <span>Items: {totalItems}</span>
            <span>{totalPrice.toLocaleString()}đ</span>
          </div>
          <div className="flex justify-between">
            <span>Shipping:</span>
            <span>Free</span>
          </div>
        </div>
        <div className="text-lg font-bold flex justify-between">
          <span>Total:</span>
          <span>{totalPrice.toLocaleString()}đ</span>
        </div>
        <button className="w-full mt-4 bg-green-600 text-white py-2 rounded">
          Checkout
        </button>
      </div>
    </div>
  );
}

/**
 * =====================================
 * PATTERN 5: Custom Hook - useAsync
 * =====================================
 */

import { useAsync } from "@/hooks";
import { orderService } from "@/services";

export default function OrderHistoryPage() {
  const {
    data: orders,
    loading,
    error,
    execute: refetch,
  } = useAsync(
    () => orderService.getOrders(1, 10),
    true, // immediate
  );

  return (
    <div>
      <h1>Your Orders</h1>
      {loading && <div>Loading...</div>}
      {error && <div>Error: {error.message}</div>}
      {orders?.items?.map((order) => (
        <div key={order._id}>
          <h3>Order {order._id}</h3>
          <p>Status: {order.status}</p>
          <p>Total: {order.totalPrice.toLocaleString()}đ</p>
        </div>
      ))}
      <button onClick={() => refetch()}>Refresh</button>
    </div>
  );
}

/**
 * =====================================
 * PATTERN 6: Error Boundary Component
 * =====================================
 */

("use client");

import { ReactNode } from "react";

interface ErrorBoundaryProps {
  children: ReactNode;
  fallback?: (error: Error) => ReactNode;
}

export class ErrorBoundary extends React.Component<ErrorBoundaryProps> {
  state = { error: null as Error | null };

  static getDerivedStateFromError(error: Error) {
    return { error };
  }

  render() {
    if (this.state.error) {
      return (
        this.props.fallback?.(this.state.error) || (
          <div className="bg-red-50 p-4 rounded border border-red-200">
            <h3 className="font-bold text-red-900">Something went wrong</h3>
            <p className="text-red-700">{this.state.error.message}</p>
          </div>
        )
      );
    }

    return this.props.children;
  }
}

// Usage:
export default function SafePage() {
  return (
    <ErrorBoundary
      fallback={(error) => (
        <div className="p-4 bg-yellow-50 border border-yellow-200 rounded">
          Failed to load products: {error.message}
        </div>
      )}
    >
      <ProductList />
    </ErrorBoundary>
  );
}

/**
 * =====================================
 * PATTERN 7: Optimistic Update Pattern
 * =====================================
 */

export function CartWithOptimisticUpdate() {
  const { cart, updateQuantity } = useCart();
  const [optimisticCart, setOptimisticCart] = useState(null);

  const handleUpdateQuantity = async (plantId: string, quantity: number) => {
    // Update UI immediately (optimistic)
    const updated = {
      ...cart,
      items: cart.items.map((item) =>
        item.plantId === plantId ? { ...item, quantity } : item,
      ),
    };
    setOptimisticCart(updated);

    // Then sync with server
    try {
      const success = await updateQuantity(plantId, quantity);
      if (!success) {
        // Revert on error
        setOptimisticCart(null);
      }
    } catch {
      setOptimisticCart(null);
    }
  };

  const displayCart = optimisticCart || cart;

  return (
    <div>
      {displayCart?.items?.map((item) => (
        <CartItemComponent
          key={item.plantId}
          item={item}
          onUpdateQuantity={handleUpdateQuantity}
        />
      ))}
    </div>
  );
}

/**
 * =====================================
 * PATTERN 8: Loading States with Skeleton
 * =====================================
 */

import { ProductCardSkeleton } from "@/components/ui";

export function ProductListWithSkeleton() {
  const { products, loading } = useProducts();

  return (
    <div className="grid grid-cols-4 gap-4">
      {loading && !products.length
        ? // Show skeletons while loading
          Array.from({ length: 12 }).map((_, i) => (
            <ProductCardSkeleton key={i} />
          ))
        : // Show products
          products.map((product) => (
            <ProductCard key={product._id} product={product} />
          ))}
    </div>
  );
}

/**
 * =====================================
 * PATTERN 9: Debounced Search
 * =====================================
 */

export function SmartSearch() {
  const [query, setQuery] = useState("");
  const debouncedQuery = useDebounce(query, 500);

  const { products } = useProducts({
    search: debouncedQuery,
    limit: 10,
  });

  return (
    <div>
      <input
        type="text"
        value={query}
        onChange={(e) => setQuery(e.target.value)}
        placeholder="Search plants..."
      />
      <p className="text-sm text-gray-500">
        {query && debouncedQuery ? "Searching..." : ""}
      </p>
      <ProductList products={products} />
    </div>
  );
}

/**
 * =====================================
 * PATTERN 10: Form with Service Submission
 * =====================================
 */

import { productService } from "@/services";
import { Product, CreateProductPayload } from "@/types";

export default function ProductFormPage() {
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");
  const [success, setSuccess] = useState(false);

  const handleSubmit = async (formData: CreateProductPayload) => {
    setLoading(true);
    setError("");
    setSuccess(false);

    try {
      const product = await productService.createProduct(formData);
      setSuccess(true);
      // Reset form, show success message
      setTimeout(() => {
        // Redirect to product detail
        window.location.href = `/plant/${product._id}`;
      }, 1000);
    } catch (err) {
      const apiError = err as any;
      setError(apiError.message || "Failed to create product");
    } finally {
      setLoading(false);
    }
  };

  return (
    <form
      onSubmit={(e) => {
        e.preventDefault();
        const formData = new FormData(e.currentTarget);
        handleSubmit(Object.fromEntries(formData) as any);
      }}
    >
      <input name="name" placeholder="Product name" required />
      <input name="price" type="number" placeholder="Price" required />
      <input name="description" placeholder="Description" />

      {error && <div className="text-red-600">{error}</div>}
      {success && <div className="text-green-600">Created successfully!</div>}

      <button type="submit" disabled={loading}>
        {loading ? "Creating..." : "Create Product"}
      </button>
    </form>
  );
}

/**
 * =====================================
 * PATTERN 11: Pagination with State
 * =====================================
 */

export function PaginatedList() {
  const [page, setPage] = useState(1);
  const { products, pagination } = useProducts({
    initialPage: page,
    limit: 20,
  });

  const handlePageChange = (newPage: number) => {
    setPage(newPage);
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  return (
    <div>
      <ProductList products={products} />

      <Pagination
        currentPage={pagination.page}
        totalPages={pagination.totalPages}
        onPageChange={handlePageChange}
      />
    </div>
  );
}

/**
 * =====================================
 * PATTERN 12: Dependent Data Fetching
 * =====================================
 */

export function DependentFetch() {
  const [productId, setProductId] = useState<string | null>(null);
  const [product, setProduct] = useState(null);
  const [loading, setLoading] = useState(false);

  // Fetch product when productId changes
  useEffect(() => {
    if (!productId) return;

    const fetchProduct = async () => {
      setLoading(true);
      try {
        const p = await productService.getProductById(productId);
        setProduct(p);
      } finally {
        setLoading(false);
      }
    };

    fetchProduct();
  }, [productId]);

  return (
    <div>
      <select onChange={(e) => setProductId(e.target.value)}>
        <option value="">Select a product</option>
        <option value="1">Product 1</option>
        <option value="2">Product 2</option>
      </select>

      {loading && <div>Loading details...</div>}
      {product && (
        <div>
          <h2>{product.name}</h2>
          <p>{product.description}</p>
        </div>
      )}
    </div>
  );
}

export {};
